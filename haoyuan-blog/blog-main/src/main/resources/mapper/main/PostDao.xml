<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.limyel.haoyuan.blog.main.dao.PostDao">

    <select id="selectPage" parameterType="com.limyel.haoyuan.blog.main.dto.post.PostFilterDTO" resultType="postDO">
        SELECT *
        FROM `main_post` t1
                 INNER JOIN `main_post_tag` t2 ON t1.id = t2.post_id
                 INNER JOIN `main_tag` t3 ON t3.id = t2.tag_id
    </select>

</mapper>